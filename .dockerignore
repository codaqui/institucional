.env
.env.local
.env.*.local

# ─── Git e CI ──────────────────────────────────────────
.git/
.github/
.gitignore

# ─── Dados/backups locais desnecessários ────────────────
old-docs-backup/
images/
tmp/

# ─── IDE e macOS ───────────────────────────────────────
