# ─────────────────────────────────────────────────────
# Discord — Sync de eventos e contagem de membros
# Token do bot Discord com intent GUILD_SCHEDULED_EVENTS
# Sem ele, os scripts de sync preservam os snapshots existentes
# ─────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=COLE_SEU_TOKEN_AQUI

# ─────────────────────────────────────────────────────
# Banco de Dados (PostgreSQL)
# ─────────────────────────────────────────────────────
DB_USER=codaqui
DB_PASSWORD=codaqui_pass
DB_NAME=codaqui_db

# ─────────────────────────────────────────────────────
# GitHub OAuth — Autenticação
# Crie em: https://github.com/settings/developers → OAuth Apps
# DEV  callback: http://localhost:3001/auth/github/callback
# PROD callback: https://api.intranet.codaqui.dev/auth/github/callback
# (criar um OAuth App por ambiente)
# ─────────────────────────────────────────────────────
GITHUB_CLIENT_ID=COLE_AQUI
GITHUB_CLIENT_SECRET=COLE_AQUI

# ─────────────────────────────────────────────────────
# JWT — Segredo para assinar tokens internos
# Gere com: openssl rand -hex 64
# ─────────────────────────────────────────────────────
JWT_SECRET=COLE_UM_SEGREDO_LONGO_AQUI

# ─────────────────────────────────────────────────────
# URLs dos serviços
# BACKEND_URL: URL pública do backend (usada no callback do GitHub OAuth)
# FRONTEND_URL: URL do frontend (usada nos redirects pós-autenticação/doação)
# ─────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────
# Stripe — Pagamentos
# Obtenha chaves em: https://dashboard.stripe.com/test/apikeys
# ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_COLE_SUA_CHAVE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_COLE_SEU_SEGREDO_AQUI
STRIPE_PUBLISHABLE_KEY=pk_COLE_SUA_CHAVE

# ─────────────────────────────────────────────────────
# Produção (compose.prod.yaml) — descomente e ajuste
# ─────────────────────────────────────────────────────
# BACKEND_URL=https://api.codaqui.dev
# FRONTEND_URL=https://codaqui.dev
